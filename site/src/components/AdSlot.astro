---
import {
  ADSENSE_CLIENT,
  ADSENSE_SLOT_TOP,
  ADSENSE_SLOT_IN_ARTICLE,
} from "../lib/adsense.mjs";

interface Props {
  variant: "top" | "in-article";
}

const { variant } = Astro.props;
const slot = variant === "top" ? ADSENSE_SLOT_TOP : ADSENSE_SLOT_IN_ARTICLE;
const isInArticle = variant === "in-article";
---

{slot ? (
  <aside class={`adslot adslot-${variant}`} aria-label="Advertisement">
    <span class="adslot-label muted">Advertisement</span>
    {isInArticle ? (
      <ins
        class="adsbygoogle"
        style="display:block; text-align:center;"
        data-ad-client={ADSENSE_CLIENT}
        data-ad-slot={slot}
        data-ad-format="fluid"
        data-ad-layout="in-article"
      />
    ) : (
      <ins
        class="adsbygoogle"
        style="display:block; text-align:center;"
        data-ad-client={ADSENSE_CLIENT}
        data-ad-slot={slot}
        data-ad-format="auto"
        data-full-width-responsive="true"
      />
    )}
  </aside>
) : null}

{/* Slot registration — one push() per <ins class="adsbygoogle"> on the page —
    is centralized in BaseLayout's adsbygoogle bootstrap so it covers both
    these top/bottom AdSlot blocks AND the in-article slot injected by
    rehype-inject-ad.mjs. Astro's markdown pipeline strips inline <script>
    tags from rehype-injected nodes, so per-slot scripts don't survive there;
    a single page-level scanner is the only path that works for both. */}
