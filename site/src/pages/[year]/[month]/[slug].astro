---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Giscus from "../../../components/Giscus.astro";
import AdSlot from "../../../components/AdSlot.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import {
  editUrlForPost,
  estimateReadingTimeMinutes,
  getAdjacentPosts,
  getRelatedPosts,
  getTranslations,
  langOf,
  ogImagePathForPost,
  urlPathForPost,
  type Locale,
} from "../../../lib/blog";

type BlogPost = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts
    .filter((p) => !p.data.draft && langOf(p) === "en")
    .flatMap((post) => {
      const m = post.slug.match(/^(\d{4})\/(\d{2})\/([^/]+)$/);
      if (!m) return [];
      return [
        {
          params: { year: m[1], month: m[2], slug: m[3] },
          props: { post },
        },
      ];
    });
}

const { post } = Astro.props as { post: BlogPost };
const { Content } = await post.render();
const canonicalUrl = Astro.url.href;
const baseUrl = import.meta.env.BASE_URL;
const ogImage = ogImagePathForPost(post);
const lang = langOf(post);

const readingMinutes = estimateReadingTimeMinutes(post.body, lang);
const pubDateIso = post.data.pubDate.toISOString().slice(0, 10);

// Translations keyed by locale, each as absolute URL for hreflang emission.
const siteOrigin = Astro.site?.origin ?? "https://startdebugging.net";
const translationsMap = await getTranslations(post);
const translations: Partial<Record<Locale, string>> = {};
for (const [l, p] of translationsMap) {
  translations[l] = siteOrigin + urlPathForPost(p);
}

// Pre-encoded share payloads. We share the canonical URL + title.
const shareTitle = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(canonicalUrl);
const shareX = `https://x.com/intent/post?text=${shareTitle}&url=${shareUrl}&via=startdebugging_`;
const shareHn = `https://news.ycombinator.com/submitlink?u=${shareUrl}&t=${shareTitle}`;
const shareReddit = `https://www.reddit.com/submit?url=${shareUrl}&title=${shareTitle}`;
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;
const editUrl = editUrlForPost(post);

// Prev/next in chronological order. `prev` is older, `next` is newer.
const { prev, next } = await getAdjacentPosts(post);

// Tag-overlap-scored related posts, with recency tiebreaker + fallback.
const related = await getRelatedPosts(post, 4);
---

<BaseLayout
  title={`${post.data.title} - Start Debugging`}
  description={post.data.description}
  includeAdsense={true}
  canonicalUrl={canonicalUrl}
  publishedDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  type="article"
  ogImage={ogImage}
  lang={lang}
  translations={Object.keys(translations).length > 1 ? translations : undefined}
  template={post.data.template}
  body={post.body}
>
  <article
    class="panel card stack prose"
    data-pagefind-body
    data-pagefind-meta={`date:${pubDateIso}${post.data.tags?.length ? `, tags:${post.data.tags.join(", ")}` : ""}`}
  >
    <div class="stack">
      <div class="row">
        <span class="pill">{pubDateIso}</span>
        {post.data.updatedDate ? (
          <span class="pill">Updated {post.data.updatedDate.toISOString().slice(0, 10)}</span>
        ) : null}
        {post.data.tags?.slice(0, 4).map((t) => (
          <a class="pill" href={`${baseUrl}tag/${t}/`}>{t}</a>
        ))}
        <a class="post-edit-link" href={editUrl} rel="noopener" target="_blank">
          <svg class="post-edit-icon" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          Edit on GitHub
        </a>
      </div>
      <h1 class="h1">{post.data.title}</h1>
      {post.data.description ? <p class="muted">{post.data.description}</p> : null}
      <div class="byline">
        <span>By <span class="byline-author">Marius Bughiu</span></span>
        <span class="byline-sep">&middot;</span>
        <span>{readingMinutes} min read</span>
        <span class="byline-sep">&middot;</span>
        <time datetime={post.data.pubDate.toISOString()}>{pubDateIso}</time>
      </div>
    </div>

    <AdSlot variant="top" />

    <Content />

    <div class="share-row" data-share-row>
      <span class="share-label">Share:</span>
      <a class="share-btn" href={shareX} rel="noopener" target="_blank" data-share="x">X</a>
      <a class="share-btn" href={shareHn} rel="noopener" target="_blank" data-share="hn">Hacker News</a>
      <a class="share-btn" href={shareReddit} rel="noopener" target="_blank" data-share="reddit">Reddit</a>
      <a class="share-btn" href={shareLinkedIn} rel="noopener" target="_blank" data-share="linkedin">LinkedIn</a>
      <button class="share-btn" type="button" data-copy-link data-copy-url={canonicalUrl}>Copy link</button>
    </div>

    <aside class="inline-subscribe" aria-labelledby="inline-subscribe-heading">
      <h2 id="inline-subscribe-heading" class="h2 inline-subscribe-heading">
        Enjoyed this post?
      </h2>
      <p class="muted inline-subscribe-copy">
        Get a short weekly digest of the best new .NET, C#, MAUI, and Flutter posts.
        One email on Monday, no spam.
      </p>
      <form
        class="inline-subscribe-form row"
        action="https://buttondown.com/api/emails/embed-subscribe/startdebugging"
        method="post"
        target="popupwindow"
        onsubmit="window.open('https://buttondown.com/startdebugging', 'popupwindow');"
      >
        <label class="sr-only" for={`inline-subscribe-${post.slug.replace(/\//g, "-")}`}>Email address</label>
        <input
          id={`inline-subscribe-${post.slug.replace(/\//g, "-")}`}
          class="inline-subscribe-input"
          type="email"
          name="email"
          placeholder="you@domain.com"
          required
          autocomplete="email"
        />
        <input type="hidden" name="tag" value={`post:${post.slug}`} />
        <button class="pill inline-subscribe-submit" type="submit">Subscribe</button>
      </form>
      <p class="muted inline-subscribe-alt">
        Or <a href={`${baseUrl}subscribe/`}>read what's in the newsletter first</a>.
      </p>
    </aside>
  </article>

  {(prev || next) ? (
    <nav class="prev-next" aria-label="Post navigation">
      {prev ? (
        <a class="prev-next-item prev-next-prev" href={`${baseUrl}${prev.slug}/`} rel="prev">
          <span class="prev-next-label">&lsaquo; Previous</span>
          <span class="prev-next-title">{prev.data.title}</span>
        </a>
      ) : <span class="prev-next-item prev-next-empty" />}
      {next ? (
        <a class="prev-next-item prev-next-next" href={`${baseUrl}${next.slug}/`} rel="next">
          <span class="prev-next-label">Next &rsaquo;</span>
          <span class="prev-next-title">{next.data.title}</span>
        </a>
      ) : <span class="prev-next-item prev-next-empty" />}
    </nav>
  ) : null}

  {related.length > 0 ? (
    <section class="stack related-section" aria-labelledby="related-heading">
      <h2 id="related-heading" class="h2 related-heading">Related posts</h2>
      <div class="stack">
        {related.map((r) => (
          <article class="panel card stack post-card">
            <div class="row">
              <span class="pill">{r.data.pubDate.toISOString().slice(0, 10)}</span>
              {r.data.tags?.slice(0, 3).map((t) => (
                <a class="pill" href={`${baseUrl}tag/${t}/`}>{t}</a>
              ))}
            </div>
            <a class="post-card-title-link stack" href={`${baseUrl}${r.slug}/`}>
              <div class="h2">{r.data.title}</div>
              {r.data.description ? <div class="muted">{r.data.description}</div> : null}
            </a>
          </article>
        ))}
      </div>
    </section>
  ) : null}

  <Giscus post={post} />

  <div class="row" style="margin-top: 14px;">
    <a class="pill" href={baseUrl}>&lt; Back</a>
  </div>
</BaseLayout>

<script>
  // Copy-link button: writes canonical URL to clipboard and gives a visual ack.
  document.querySelectorAll<HTMLButtonElement>("button[data-copy-link]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-copy-url") ?? window.location.href;
      const original = btn.textContent;
      try {
        await navigator.clipboard.writeText(url);
        btn.textContent = "Copied!";
      } catch (err) {
        btn.textContent = "Copy failed";
        console.error(err);
      }
      setTimeout(() => {
        btn.textContent = original;
      }, 1500);
    });
  });
</script>
