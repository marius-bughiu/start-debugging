---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import {
  estimateReadingTimeMinutes,
  getAdjacentPosts,
  getRelatedPosts,
  ogImagePathForPost,
} from "../../../lib/blog";

type BlogPost = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts
    .filter((p) => !p.data.draft)
    .flatMap((post) => {
      const m = post.slug.match(/^(\d{4})\/(\d{2})\/([^/]+)$/);
      if (!m) return [];
      return [
        {
          params: { year: m[1], month: m[2], slug: m[3] },
          props: { post },
        },
      ];
    });
}

const { post } = Astro.props as { post: BlogPost };
const { Content } = await post.render();
const canonicalUrl = Astro.url.href;
const baseUrl = import.meta.env.BASE_URL;
const ogImage = ogImagePathForPost(post);

const readingMinutes = estimateReadingTimeMinutes(post.body);
const pubDateIso = post.data.pubDate.toISOString().slice(0, 10);

// Pre-encoded share payloads. We share the canonical URL + title.
const shareTitle = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(canonicalUrl);
const shareX = `https://x.com/intent/post?text=${shareTitle}&url=${shareUrl}&via=mariusbughiu`;
const shareHn = `https://news.ycombinator.com/submitlink?u=${shareUrl}&t=${shareTitle}`;
const shareReddit = `https://www.reddit.com/submit?url=${shareUrl}&title=${shareTitle}`;
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;

// Prev/next in chronological order. `prev` is older, `next` is newer.
const { prev, next } = await getAdjacentPosts(post);

// Tag-overlap-scored related posts, with recency tiebreaker + fallback.
const related = await getRelatedPosts(post, 4);
---

<BaseLayout
  title={`${post.data.title} - Start Debugging`}
  description={post.data.description}
  includeAdsense={true}
  canonicalUrl={canonicalUrl}
  publishedDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  type="article"
  ogImage={ogImage}
>
  <article
    class="panel card stack prose"
    data-pagefind-body
    data-pagefind-meta={`date:${pubDateIso}${post.data.tags?.length ? `, tags:${post.data.tags.join(", ")}` : ""}`}
  >
    <div class="stack">
      <div class="row">
        <span class="pill">{pubDateIso}</span>
        {post.data.updatedDate ? (
          <span class="pill">Updated {post.data.updatedDate.toISOString().slice(0, 10)}</span>
        ) : null}
        {post.data.tags?.slice(0, 4).map((t) => (
          <a class="pill" href={`${baseUrl}tag/${t}/`}>{t}</a>
        ))}
      </div>
      <h1 class="h1">{post.data.title}</h1>
      {post.data.description ? <p class="muted">{post.data.description}</p> : null}
      <div class="byline">
        <span>By <span class="byline-author">Marius Bughiu</span></span>
        <span class="byline-sep">&middot;</span>
        <span>{readingMinutes} min read</span>
        <span class="byline-sep">&middot;</span>
        <time datetime={post.data.pubDate.toISOString()}>{pubDateIso}</time>
      </div>
    </div>

    <Content />

    <div class="share-row" data-share-row>
      <span class="share-label">Share:</span>
      <a class="share-btn" href={shareX} rel="noopener" target="_blank" data-share="x">X</a>
      <a class="share-btn" href={shareHn} rel="noopener" target="_blank" data-share="hn">Hacker News</a>
      <a class="share-btn" href={shareReddit} rel="noopener" target="_blank" data-share="reddit">Reddit</a>
      <a class="share-btn" href={shareLinkedIn} rel="noopener" target="_blank" data-share="linkedin">LinkedIn</a>
      <button class="share-btn" type="button" data-copy-link data-copy-url={canonicalUrl}>Copy link</button>
    </div>
  </article>

  {(prev || next) ? (
    <nav class="prev-next" aria-label="Post navigation">
      {prev ? (
        <a class="prev-next-item prev-next-prev" href={`${baseUrl}${prev.slug}/`} rel="prev">
          <span class="prev-next-label">&lsaquo; Previous</span>
          <span class="prev-next-title">{prev.data.title}</span>
        </a>
      ) : <span class="prev-next-item prev-next-empty" />}
      {next ? (
        <a class="prev-next-item prev-next-next" href={`${baseUrl}${next.slug}/`} rel="next">
          <span class="prev-next-label">Next &rsaquo;</span>
          <span class="prev-next-title">{next.data.title}</span>
        </a>
      ) : <span class="prev-next-item prev-next-empty" />}
    </nav>
  ) : null}

  {related.length > 0 ? (
    <section class="stack related-section" aria-labelledby="related-heading">
      <h2 id="related-heading" class="h2 related-heading">Related posts</h2>
      <div class="stack">
        {related.map((r) => (
          <article class="panel card stack post-card">
            <div class="row">
              <span class="pill">{r.data.pubDate.toISOString().slice(0, 10)}</span>
              {r.data.tags?.slice(0, 3).map((t) => (
                <a class="pill" href={`${baseUrl}tag/${t}/`}>{t}</a>
              ))}
            </div>
            <a class="post-card-title-link stack" href={`${baseUrl}${r.slug}/`}>
              <div class="h2">{r.data.title}</div>
              {r.data.description ? <div class="muted">{r.data.description}</div> : null}
            </a>
          </article>
        ))}
      </div>
    </section>
  ) : null}

  <div class="row" style="margin-top: 14px;">
    <a class="pill" href={baseUrl}>&lt; Back</a>
  </div>
</BaseLayout>

<script>
  // Copy-link button: writes canonical URL to clipboard and gives a visual ack.
  document.querySelectorAll<HTMLButtonElement>("button[data-copy-link]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-copy-url") ?? window.location.href;
      const original = btn.textContent;
      try {
        await navigator.clipboard.writeText(url);
        btn.textContent = "Copied!";
      } catch (err) {
        btn.textContent = "Copy failed";
        console.error(err);
      }
      setTimeout(() => {
        btn.textContent = original;
      }, 1500);
    });
  });
</script>
