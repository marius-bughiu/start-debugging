---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog - Start Debugging" description="Articles and notes.">
  <section class="stack">
    <h1 class="h1">Blog</h1>
    <p class="muted">Static posts generated at build time.</p>
  </section>

  <section class="stack" style="margin-top: 18px;">
    {posts.map((post) => (
      <a class="panel card stack" href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}>
        <div class="row">
          <span class="pill">{post.data.pubDate.toISOString().slice(0, 10)}</span>
          {post.data.tags?.slice(0, 3).map((t) => <span class="pill">{t}</span>)}
        </div>
        <div class="stack">
          <div class="h2">{post.data.title}</div>
          {post.data.description ? <div class="muted">{post.data.description}</div> : null}
        </div>
      </a>
    ))}

    {posts.length === 0 ? (
      <div class="panel card muted">No posts yet.</div>
    ) : null}
  </section>
</BaseLayout>

