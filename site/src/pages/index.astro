---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedBlogPosts } from "../lib/blog";
import type { BlogPost } from "../lib/blog";
import featuredData from "../data/featured.json";

const PAGE_SIZE = 10;
const baseUrl = import.meta.env.BASE_URL;

const allPosts = await getPublishedBlogPosts();
const posts = allPosts.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));

// Resolve featured slugs against the published-post index. Missing/renamed
// slugs are dropped silently (logged in dev) so the homepage keeps rendering.
type FeaturedData = { slugs: string[] };
const featuredSlugs = (featuredData as FeaturedData).slugs ?? [];
const postBySlug = new Map(allPosts.map((p) => [p.slug, p] as const));
const featured: BlogPost[] = [];
for (const slug of featuredSlugs) {
  const p = postBySlug.get(slug);
  if (p) featured.push(p);
  else if (import.meta.env.DEV) {
    console.warn(`[homepage featured] missing slug: ${slug}`);
  }
}

const tagline =
  "Daily notes on .NET, C#, EF Core, MAUI, Blazor, and Flutter - for developers who ship.";
---

<BaseLayout
  title="Start Debugging"
  description={tagline}
  canonicalUrl={Astro.url.href}
  type="website"
>
  <section class="stack home-hero">
    <p class="home-tagline">{tagline}</p>
    <div class="row">
      <a class="pill home-cta" href={`${baseUrl}start-here/`}>Start here &rsaquo;</a>
      <a class="pill" href={`${baseUrl}tags/`}>Tags</a>
      <a class="pill" href={`${baseUrl}archive/`}>Archive</a>
    </div>
  </section>

  {featured.length > 0 ? (
    <section class="stack featured-section" aria-labelledby="featured-heading">
      <h2 id="featured-heading" class="h2 related-heading">Featured</h2>
      <div class="featured-grid">
        {featured.map((post) => (
          <article class="panel card stack post-card featured-card">
            <div class="row">
              <span class="pill">{post.data.pubDate.toISOString().slice(0, 10)}</span>
              {post.data.tags?.slice(0, 2).map((t) => (
                <a class="pill" href={`${baseUrl}tag/${t}/`}>{t}</a>
              ))}
            </div>
            <a class="post-card-title-link stack" href={`${baseUrl}${post.slug}/`}>
              <div class="h2">{post.data.title}</div>
              {post.data.description ? <div class="muted">{post.data.description}</div> : null}
            </a>
          </article>
        ))}
      </div>
    </section>
  ) : null}

  <section class="stack" style="margin-top: 18px;">
    <h2 class="h2 related-heading">Latest</h2>
    {posts.map((post) => (
      <article class="panel card stack post-card">
        <div class="row">
          <span class="pill">{post.data.pubDate.toISOString().slice(0, 10)}</span>
          {post.data.tags?.slice(0, 3).map((t) => (
            <a class="pill" href={`${baseUrl}tag/${t}/`}>{t}</a>
          ))}
        </div>
        <a class="post-card-title-link stack" href={`${baseUrl}${post.slug}/`}>
          <div class="h2">{post.data.title}</div>
          {post.data.description ? <div class="muted">{post.data.description}</div> : null}
        </a>
      </article>
    ))}

    {posts.length === 0 ? <div class="panel card muted">No posts yet.</div> : null}
  </section>

  {totalPages > 1 ? (
    <div class="row" style="margin-top: 14px;">
      <span class="muted">Page 1 of {totalPages}</span>
      <a class="pill" href={`${baseUrl}page/2/`}>Next</a>
    </div>
  ) : null}
</BaseLayout>
