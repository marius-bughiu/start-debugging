---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedBlogPosts } from "../../lib/blog";
import type { BlogPost } from "../../lib/blog";

const baseUrl = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const allPosts = await getPublishedBlogPosts();
  const tagMap = new Map<string, BlogPost[]>();

  for (const post of allPosts) {
    for (const tag of post.data.tags ?? []) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }

  const paths: {
    params: { slug: string };
    props: { tag: string; posts: BlogPost[]; totalCount: number; page: number; totalPages: number };
  }[] = [];

  for (const [tag, tagPosts] of tagMap) {
    const totalPages = Math.max(1, Math.ceil(tagPosts.length / PAGE_SIZE));
    for (let page = 1; page <= totalPages; page++) {
      const start = (page - 1) * PAGE_SIZE;
      paths.push({
        params: { slug: page === 1 ? tag : `${tag}/${page}` },
        props: {
          tag,
          posts: tagPosts.slice(start, start + PAGE_SIZE),
          totalCount: tagPosts.length,
          page,
          totalPages,
        },
      });
    }
  }

  return paths;
}

const { tag, posts, totalCount, page, totalPages } = Astro.props;

const tagBase = `${baseUrl}tag/${tag}/`;
const prevHref = page > 1 ? (page === 2 ? tagBase : `${tagBase}${page - 1}/`) : null;
const nextHref = page < totalPages ? `${tagBase}${page + 1}/` : null;
---

<BaseLayout
  title={`Posts tagged "${tag}"${page > 1 ? ` (Page ${page})` : ""} - Start Debugging`}
  description={`All articles tagged with ${tag}.`}
  canonicalUrl={Astro.url.href}
  type="website"
>
  <section class="stack">
    <h1 class="h1">Tag: {tag}</h1>
    <p class="muted">
      {totalCount} post{totalCount !== 1 ? "s" : ""}
      {totalPages > 1 ? <> &middot; Page {page} of {totalPages}</> : null}
    </p>
  </section>

  <section class="stack" style="margin-top: 18px;">
    {posts.map((post) => (
      <a class="panel card stack" href={`${baseUrl}${post.slug}/`}>
        <div class="row">
          <span class="pill">{post.data.pubDate.toISOString().slice(0, 10)}</span>
          {post.data.tags?.slice(0, 3).map((t) => <span class="pill">{t}</span>)}
        </div>
        <div class="stack">
          <div class="h2">{post.data.title}</div>
          {post.data.description ? <div class="muted">{post.data.description}</div> : null}
        </div>
      </a>
    ))}

    {posts.length === 0 ? <div class="panel card muted">No posts found.</div> : null}
  </section>

  <div class="row" style="margin-top: 14px;">
    {prevHref ? <a class="pill" href={prevHref}>Prev</a> : null}
    {nextHref ? <a class="pill" href={nextHref}>Next</a> : null}
  </div>
</BaseLayout>
