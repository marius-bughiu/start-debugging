---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Giscus from "../../../../components/Giscus.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import {
  editUrlForPost,
  estimateReadingTimeMinutes,
  getAdjacentPosts,
  getRelatedPosts,
  getTranslations,
  isLocale,
  langOf,
  ogImagePathForPost,
  urlPathForPost,
  type Locale,
} from "../../../../lib/blog";
import { t } from "../../../../i18n";

type BlogPost = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts
    .filter((p) => !p.data.draft && langOf(p) !== "en")
    .flatMap((post) => {
      const lang = langOf(post);
      const m = post.slug.match(/^[^/]+\/(\d{4})\/(\d{2})\/([^/]+)$/);
      if (!m) return [];
      return [
        {
          params: { lang, year: m[1], month: m[2], slug: m[3] },
          props: { post },
        },
      ];
    });
}

const { post } = Astro.props as { post: BlogPost };
const { Content } = await post.render();
const canonicalUrl = Astro.url.href;
const baseUrl = import.meta.env.BASE_URL;
const ogImage = ogImagePathForPost(post);
const lang = langOf(post);

// Defensive: ensure params.lang matches the post's lang. Without this, a
// stray route like /es/2026/04/slug/ for an English post would 404 silently.
if (!isLocale(Astro.params.lang ?? "") || Astro.params.lang !== lang) {
  return Astro.redirect("/404");
}

const readingMinutes = estimateReadingTimeMinutes(post.body, lang);
const pubDateIso = post.data.pubDate.toISOString().slice(0, 10);

const shareTitle = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(canonicalUrl);
const shareX = `https://x.com/intent/post?text=${shareTitle}&url=${shareUrl}&via=startdebugging_`;
const shareHn = `https://news.ycombinator.com/submitlink?u=${shareUrl}&t=${shareTitle}`;
const shareReddit = `https://www.reddit.com/submit?url=${shareUrl}&title=${shareTitle}`;
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`;
const editUrl = editUrlForPost(post);

const { prev, next } = await getAdjacentPosts(post);
const related = await getRelatedPosts(post, 4);

const siteOrigin = Astro.site?.origin ?? "https://startdebugging.net";
const translationsMap = await getTranslations(post);
const translations: Partial<Record<Locale, string>> = {};
for (const [l, p] of translationsMap) {
  translations[l] = siteOrigin + urlPathForPost(p);
}

const langPrefix = `${baseUrl}${lang}/`;
---

<BaseLayout
  title={`${post.data.title} - Start Debugging`}
  description={post.data.description}
  includeAdsense={true}
  canonicalUrl={canonicalUrl}
  publishedDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  type="article"
  ogImage={ogImage}
  lang={lang}
  translations={Object.keys(translations).length > 1 ? translations : undefined}
  template={post.data.template}
  body={post.body}
>
  <article
    class="panel card stack prose"
    data-pagefind-body
    data-pagefind-meta={`date:${pubDateIso}${post.data.tags?.length ? `, tags:${post.data.tags.join(", ")}` : ""}, lang:${lang}`}
  >
    <div class="stack">
      <div class="row">
        <span class="pill">{pubDateIso}</span>
        {post.data.updatedDate ? (
          <span class="pill">{t("post.updated", lang)} {post.data.updatedDate.toISOString().slice(0, 10)}</span>
        ) : null}
        {post.data.tags?.slice(0, 4).map((tag) => (
          <a class="pill" href={`${langPrefix}tag/${tag}/`}>{tag}</a>
        ))}
        <a class="post-edit-link" href={editUrl} rel="noopener" target="_blank">{t("post.editOnGitHub", lang)}</a>
      </div>
      <h1 class="h1">{post.data.title}</h1>
      {post.data.description ? <p class="muted">{post.data.description}</p> : null}
      <div class="byline">
        <span>{t("post.by", lang)} <span class="byline-author">Marius Bughiu</span></span>
        <span class="byline-sep">&middot;</span>
        <span>{readingMinutes} {t("post.minRead", lang)}</span>
        <span class="byline-sep">&middot;</span>
        <time datetime={post.data.pubDate.toISOString()}>{pubDateIso}</time>
      </div>
    </div>

    <Content />

    <div class="share-row" data-share-row>
      <span class="share-label">{t("post.share", lang)}</span>
      <a class="share-btn" href={shareX} rel="noopener" target="_blank" data-share="x">X</a>
      <a class="share-btn" href={shareHn} rel="noopener" target="_blank" data-share="hn">Hacker News</a>
      <a class="share-btn" href={shareReddit} rel="noopener" target="_blank" data-share="reddit">Reddit</a>
      <a class="share-btn" href={shareLinkedIn} rel="noopener" target="_blank" data-share="linkedin">LinkedIn</a>
      <button class="share-btn" type="button" data-copy-link data-copy-url={canonicalUrl}>{t("post.copyLink", lang)}</button>
    </div>
  </article>

  {(prev || next) ? (
    <nav class="prev-next" aria-label="Post navigation">
      {prev ? (
        <a class="prev-next-item prev-next-prev" href={urlPathForPost(prev)} rel="prev">
          <span class="prev-next-label">{t("post.prev", lang)}</span>
          <span class="prev-next-title">{prev.data.title}</span>
        </a>
      ) : <span class="prev-next-item prev-next-empty" />}
      {next ? (
        <a class="prev-next-item prev-next-next" href={urlPathForPost(next)} rel="next">
          <span class="prev-next-label">{t("post.next", lang)}</span>
          <span class="prev-next-title">{next.data.title}</span>
        </a>
      ) : <span class="prev-next-item prev-next-empty" />}
    </nav>
  ) : null}

  {related.length > 0 ? (
    <section class="stack related-section" aria-labelledby="related-heading">
      <h2 id="related-heading" class="h2 related-heading">{t("post.related", lang)}</h2>
      <div class="stack">
        {related.map((r) => (
          <article class="panel card stack post-card">
            <div class="row">
              <span class="pill">{r.data.pubDate.toISOString().slice(0, 10)}</span>
              {r.data.tags?.slice(0, 3).map((tag) => (
                <a class="pill" href={`${langPrefix}tag/${tag}/`}>{tag}</a>
              ))}
            </div>
            <a class="post-card-title-link stack" href={urlPathForPost(r)}>
              <div class="h2">{r.data.title}</div>
              {r.data.description ? <div class="muted">{r.data.description}</div> : null}
            </a>
          </article>
        ))}
      </div>
    </section>
  ) : null}

  <Giscus post={post} />

  <div class="row" style="margin-top: 14px;">
    <a class="pill" href={langPrefix}>{t("nav.back", lang)}</a>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>("button[data-copy-link]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-copy-url") ?? window.location.href;
      const original = btn.textContent;
      try {
        await navigator.clipboard.writeText(url);
        btn.textContent = btn.dataset.copiedLabel ?? "Copied!";
      } catch (err) {
        btn.textContent = btn.dataset.copyFailedLabel ?? "Copy failed";
        console.error(err);
      }
      setTimeout(() => {
        btn.textContent = original;
      }, 1500);
    });
  });
</script>
