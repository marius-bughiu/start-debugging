---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildLocaleUrlMap,
  isLocale,
  LOCALES,
  type Locale,
} from "../../lib/blog";
import { t } from "../../i18n";

export async function getStaticPaths() {
  return LOCALES.filter((l) => l !== "en").map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Locale };

if (!isLocale(Astro.params.lang ?? "") || Astro.params.lang === "en") {
  return Astro.redirect("/404");
}

const baseUrl = import.meta.env.BASE_URL;
const langPrefix = `${baseUrl}${lang}/`;
const siteOrigin = Astro.site?.origin ?? "https://startdebugging.net";

const rssHref = `${langPrefix}rss.xml`;
const body1 = t("about.body1", lang);
const body2 = t("about.body2", lang);
const bodyWalter = t("about.bodyWalter", lang);
const body3 = t("about.body3", lang).replace("{rss}", rssHref);

const translations = buildLocaleUrlMap(siteOrigin, (l) =>
  l === "en" ? "/about/" : `/${l}/about/`,
);
---

<BaseLayout
  title={`${t("about.heading", lang)} - Start Debugging`}
  description={t("about.tagline", lang)}
  canonicalUrl={Astro.url.href}
  type="website"
  lang={lang}
  translations={translations}
>
  <article class="panel card stack prose">
    <div class="stack">
      <h1 class="h1">{t("about.heading", lang)}</h1>
      <p class="muted">{t("about.tagline", lang)}</p>
    </div>

    <p set:html={body1} />
    <p set:html={body2} />
    <p set:html={bodyWalter} />
    <p set:html={body3} />
  </article>

  <div class="row" style="margin-top: 14px;">
    <a class="pill" href={langPrefix}>{t("nav.back", lang)}</a>
  </div>
</BaseLayout>
