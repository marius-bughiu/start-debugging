---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getPublishedPillars,
  getPillarPosts,
  getPillarTranslations,
  isLocale,
  langOf,
  LOCALES,
  urlPathForPillar,
  urlPathForPost,
  type Locale,
  type Pillar,
} from "../../../lib/blog";
import { t } from "../../../i18n";

export async function getStaticPaths() {
  const paths: {
    params: { lang: string; slug: string };
    props: { pillar: Pillar; lang: Locale };
  }[] = [];

  for (const lang of LOCALES) {
    if (lang === "en") continue;
    const pillars = await getPublishedPillars(lang);
    for (const pillar of pillars) {
      // Translated pillar slug is `{lang}/base-slug`. Strip the prefix so the
      // URL segment matches the English pillar slug (e.g. `csharp-14-features`).
      const m = pillar.slug.match(new RegExp(`^${lang}/(.+)$`));
      const slug = m ? m[1] : pillar.slug;
      paths.push({
        params: { lang, slug },
        props: { pillar, lang },
      });
    }
  }

  return paths;
}

const baseUrl = import.meta.env.BASE_URL;

interface Props {
  pillar: Pillar;
  lang: Locale;
}
const { pillar, lang } = Astro.props;

if (!isLocale(Astro.params.lang ?? "") || Astro.params.lang === "en") {
  return Astro.redirect("/404");
}

const posts = await getPillarPosts(pillar.data.indexTags, lang);
const { Content } = await pillar.render();

const siteOrigin = Astro.site?.origin ?? "https://startdebugging.net";
const translationsMap = await getPillarTranslations(pillar);
const translations: Partial<Record<Locale, string>> = {};
for (const [l, p] of translationsMap) {
  translations[l] = siteOrigin + urlPathForPillar(p);
}

// Group posts by YYYY/MM for a scannable table of contents.
const groups = new Map<string, typeof posts>();
for (const p of posts) {
  const base = p.slug.replace(new RegExp(`^${lang}/`), "");
  const m = base.match(/^(\d{4})\/(\d{2})\//);
  const key = m ? `${m[1]}-${m[2]}` : "other";
  if (!groups.has(key)) groups.set(key, [] as typeof posts);
  groups.get(key)!.push(p);
}
const groupKeys = Array.from(groups.keys()).sort((a, b) => b.localeCompare(a));

const langPrefix = `${baseUrl}${lang}/`;
---

<BaseLayout
  title={`${pillar.data.title} - Start Debugging`}
  description={pillar.data.description}
  canonicalUrl={Astro.url.href}
  type="article"
  publishedDate={pillar.data.pubDate}
  updatedDate={pillar.data.updatedDate ?? pillar.data.pubDate}
  lang={lang}
  translations={Object.keys(translations).length > 1 ? translations : undefined}
>
  <article class="stack">
    <h1 class="h1">{pillar.data.title}</h1>
    {pillar.data.tagline ? (
      <p class="muted" style="font-size: 18px;">{pillar.data.tagline}</p>
    ) : null}

    <section class="prose stack">
      <Content />
    </section>

    <section class="stack pillar-index" style="margin-top: 24px;">
      <h2 class="h2">{t("pillars.index", lang)} ({posts.length} {posts.length === 1 ? t("postCount.singular", lang) : t("postCount.plural", lang)})</h2>
      {groupKeys.map((key) => {
        const items = groups.get(key)!;
        const label = key === "other" ? t("pillars.other", lang) : key.replace("-", " / ");
        return (
          <section class="stack pillar-index-group">
            <h3 class="h3" style="margin-top: 12px;">{label}</h3>
            <ul class="pillar-index-list">
              {items.map((p) => (
                <li class="pillar-index-item">
                  <a href={urlPathForPost(p)}>{p.data.title}</a>
                  {p.data.description ? (
                    <p class="muted">{p.data.description}</p>
                  ) : null}
                </li>
              ))}
            </ul>
          </section>
        );
      })}
    </section>
  </article>

  <div class="row" style="margin-top: 18px;">
    <a class="pill" href={`${langPrefix}pillars/`}>{t("pillars.all", lang)}</a>
    <a class="pill" href={langPrefix}>{t("nav.home", lang)}</a>
  </div>
</BaseLayout>
