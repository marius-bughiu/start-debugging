---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildLocaleUrlMap,
  isLocale,
  LOCALES,
  type Locale,
} from "../../lib/blog";
import { t } from "../../i18n";

export async function getStaticPaths() {
  return LOCALES.filter((l) => l !== "en").map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

const { lang } = Astro.props as { lang: Locale };

if (!isLocale(Astro.params.lang ?? "") || Astro.params.lang === "en") {
  return Astro.redirect("/404");
}

const baseUrl = import.meta.env.BASE_URL;
const langPrefix = `${baseUrl}${lang}/`;
const siteOrigin = Astro.site?.origin ?? "https://startdebugging.net";

const rssHref = `${langPrefix}rss.xml`;
const finePrint = t("subscribe.finePrint", lang);
const altBody = t("subscribe.alt.body", lang).replace("{rss}", rssHref);

const translations = buildLocaleUrlMap(siteOrigin, (l) =>
  l === "en" ? "/subscribe/" : `/${l}/subscribe/`,
);
---

<BaseLayout
  title={`${t("subscribe.heading", lang)} - Start Debugging`}
  description={t("subscribe.footer.blurb", lang)}
  canonicalUrl={Astro.url.href}
  lang={lang}
  translations={translations}
>
  <section class="panel card stack subscribe-hero" aria-labelledby="subscribe-heading">
    <h1 id="subscribe-heading" class="h1">{t("subscribe.heading", lang)}</h1>
    <p class="lead" set:html={t("subscribe.lead", lang)} />

    <form
      class="inline-subscribe-form row"
      action="https://buttondown.com/api/emails/embed-subscribe/startdebugging"
      method="post"
      target="popupwindow"
      onsubmit="window.open('https://buttondown.com/startdebugging', 'popupwindow');"
    >
      <label class="sr-only" for="subscribe-email">Email</label>
      <input
        id="subscribe-email"
        class="inline-subscribe-input"
        type="email"
        name="email"
        placeholder={t("subscribe.placeholder", lang)}
        required
        autocomplete="email"
      />
      <input type="hidden" name="tag" value="subscribe-page" />
      <button class="pill inline-subscribe-submit" type="submit">{t("subscribe.submit", lang)}</button>
    </form>
    <p class="muted subscribe-fine-print" set:html={finePrint} />
  </section>

  <section class="stack subscribe-why" aria-labelledby="why-heading">
    <h2 id="why-heading" class="h2">{t("subscribe.what.heading", lang)}</h2>
    <ul class="subscribe-bullets">
      <li set:html={t("subscribe.what.bullet1", lang)} />
      <li set:html={t("subscribe.what.bullet2", lang)} />
      <li set:html={t("subscribe.what.bullet3", lang)} />
    </ul>

    <h2 class="h2">{t("subscribe.alt.heading", lang)}</h2>
    <p set:html={altBody} />

    <h2 class="h2">{t("subscribe.privacy.heading", lang)}</h2>
    <p>{t("subscribe.privacy.body", lang)}</p>

    <div class="row">
      <a class="pill" href={langPrefix}>&lt; {t("nav.home", lang)}</a>
      <a class="pill" href={`${langPrefix}start-here/`}>{t("nav.startHere", lang)}</a>
      <a class="pill" href={`${langPrefix}archive/`}>{t("nav.archive", lang)}</a>
    </div>
  </section>
</BaseLayout>
