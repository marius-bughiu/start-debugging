---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  includeAdsense?: boolean;
  canonicalUrl?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  type?: "website" | "article";
  /**
   * Site-relative path to the OG/Twitter image for this page, e.g.
   * `/og/2026/04/my-slug.png`. Falls back to `/og/default.png` when not
   * provided. Post pages should pass this explicitly.
   */
  ogImage?: string;
}

const {
  title,
  description,
  includeAdsense = false,
  canonicalUrl,
  publishedDate,
  updatedDate,
  tags,
  type = "website",
  ogImage,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const siteUrl = Astro.site?.origin ?? "https://startdebugging.net";
const siteName = "Start Debugging";
const canonical = canonicalUrl ?? Astro.url.href;

// Absolute OG image URL. Fall back to the site-wide default card.
const ogImagePath = ogImage ?? "/og/default.png";
const ogImageUrl = new URL(ogImagePath, siteUrl).href;

// Author identity used in JSON-LD (mirrors site/src/pages/about.astro).
const author = {
  "@type": "Person",
  name: "Marius Bughiu",
  url: `${siteUrl}/about/`,
  sameAs: [
    "https://github.com/marius-bughiu",
    "https://x.com/mariusbughiu",
    "https://www.linkedin.com/in/mariusbughiu/",
  ],
};

const publisher = {
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: `${siteUrl}/logo-512.png`,
    width: 512,
    height: 512,
  },
};

// JSON-LD structured data.
const primaryJsonLd =
  type === "article" && publishedDate
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title.replace(/ - Start Debugging$/, ""),
        description: description ?? "",
        url: canonical,
        mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
        image: [ogImageUrl],
        datePublished: publishedDate.toISOString(),
        ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
        ...(tags?.length ? { keywords: tags.join(", ") } : {}),
        author,
        publisher,
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: siteName,
        url: siteUrl,
        publisher,
      };

// BreadcrumbList for post pages. We only include URLs that actually resolve
// (Home -> post title). Year/month archive pages are a Phase 2 task; once
// they exist, add intermediate items here.
let breadcrumbJsonLd: Record<string, unknown> | null = null;
if (type === "article" && publishedDate) {
  breadcrumbJsonLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: siteName,
        item: siteUrl + "/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: title.replace(/ - Start Debugging$/, ""),
        item: canonical,
      },
    ],
  };
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={`${siteUrl}/rss.xml`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type === "article" ? "article" : "website"} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {type === "article" && publishedDate ? (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    ) : null}
    {type === "article" && updatedDate ? (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    ) : null}
    {type === "article" && tags?.length
      ? tags.map((t) => <meta property="article:tag" content={t} />)
      : null}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mariusbughiu" />
    <meta name="twitter:creator" content="@mariusbughiu" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(primaryJsonLd)} />
    {breadcrumbJsonLd ? (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    ) : null}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QFYE38MD6S"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-QFYE38MD6S');
    </script>

    {includeAdsense ? (
      <>
        <!-- Google AdSense -->
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1537458730659685"
     crossorigin="anonymous"></script>
      </>
    ) : null}
  </head>
  <body>
    <header>
      <div class="row">
        <a class="pill" href={baseUrl}>
          Start Debugging
        </a>
        <!--<nav class="row">
          <a href={`${baseUrl}`}>Home</a>
          <a href={`${baseUrl}`}>Blog</a>
        </nav>-->
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <nav class="footer-nav row">
        <a href={`${baseUrl}about/`}>About</a>
        <a href={`${siteUrl}/rss.xml`}>RSS</a>
        <a href="https://github.com/marius-bughiu/start-debugging" rel="noopener" target="_blank">GitHub</a>
      </nav>
      <div class="muted footer-copy">
        &copy; {new Date().getUTCFullYear()} Marius Bughiu. Built with Astro.
      </div>
    </footer>
  </body>
</html>
