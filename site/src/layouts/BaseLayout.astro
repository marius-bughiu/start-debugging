---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  includeAdsense?: boolean;
}

const { title, description, includeAdsense = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// Google integrations (hardcoded)
const GA_MEASUREMENT_ID = "G-QFYE38MD6S";
const ADSENSE_CLIENT_ID = "ca-pub-1537458730659685";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />

    <!-- Google Analytics (GA4) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`} />
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID);
    </script>

    {includeAdsense ? (
      <>
        <!-- Google AdSense -->
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT_ID}`}
          crossorigin="anonymous"
        />
      </>
    ) : null}
  </head>
  <body>
    <header>
      <div class="row">
        <a class="pill" href={baseUrl}>
          Start Debugging
        </a>
        <!--<nav class="row">
          <a href={`${baseUrl}`}>Home</a>
          <a href={`${baseUrl}`}>Blog</a>
        </nav>-->
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="muted">

      </div>
    </footer>
  </body>
</html>

