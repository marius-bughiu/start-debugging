---
import "../styles/global.css";
import {
  LOCALES,
  LOCALE_HREFLANG,
  LOCALE_NATIVE_NAME,
  LOCALE_OG,
  LOCALE_SHORT_CODE,
  type Locale,
} from "../lib/blog";
import {
  buildFaqPageJsonLd,
  buildHowToJsonLd,
  extractFaqFromMarkdown,
  extractHowToFromMarkdown,
} from "../lib/schema";
import { t } from "../i18n";

export interface Props {
  title: string;
  description?: string;
  includeAdsense?: boolean;
  canonicalUrl?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  type?: "website" | "article";
  /**
   * Site-relative path to the OG/Twitter image for this page, e.g.
   * `/og/2026/04/my-slug.png`. Falls back to `/og/default.png` when not
   * provided. Post pages should pass this explicitly.
   */
  ogImage?: string;
  /**
   * Content language of this page. Drives <html lang>, og:locale, and
   * JSON-LD inLanguage. Defaults to English.
   */
  lang?: Locale;
  /**
   * Absolute URLs of this page's translations, keyed by locale. Powers
   * hreflang alternates. Pass only the locales that actually have a
   * translation; the current page's own locale should also be included.
   * Omit for pages without translations.
   */
  translations?: Partial<Record<Locale, string>>;
  /**
   * Frontmatter `template` for posts using the templated content shapes
   * defined under `content-strategy/templates/*.md`. Drives extra schema.org
   * emission: `error-page` → FAQPage, `how-to`/`migration` → HowTo. Passed
   * straight through from post frontmatter.
   */
  template?: "error-page" | "how-to" | "migration" | "vs";
  /**
   * Raw markdown body for posts. Used by the FAQPage / HowTo extractors. Only
   * needed when `template` is set; ignored otherwise.
   */
  body?: string;
}

const {
  title,
  description,
  includeAdsense = false,
  canonicalUrl,
  publishedDate,
  updatedDate,
  tags,
  type = "website",
  ogImage,
  lang = "en",
  translations,
  template,
  body,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const siteUrl = Astro.site?.origin ?? "https://startdebugging.net";
const siteName = "Start Debugging";
const canonical = canonicalUrl ?? Astro.url.href;

const ogImagePath = ogImage ?? "/og/default.png";
const ogImageUrl = new URL(ogImagePath, siteUrl).href;

const htmlLang = LOCALE_HREFLANG[lang];
const ogLocale = LOCALE_OG[lang];

// Derive alternate locales present on this page (excluding the current one).
const translationEntries = translations
  ? (Object.entries(translations).filter(
      ([l, href]) => !!href && l !== lang,
    ) as [Locale, string][])
  : [];

// Show the language switcher only when at least one translation of the
// current page exists. Otherwise the control would mislead readers.
const showLangSwitcher = translationEntries.length > 0;

// Author identity used in JSON-LD (mirrors site/src/pages/about.astro).
const author = {
  "@type": "Person",
  name: "Marius Bughiu",
  url: `${siteUrl}/about/`,
  sameAs: [
    "https://github.com/marius-bughiu",
    "https://x.com/mariusbughiu",
    "https://www.linkedin.com/in/mariusbughiu/",
  ],
};

const publisher = {
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: `${siteUrl}/logo-512.png`,
    width: 512,
    height: 512,
  },
};

// JSON-LD structured data.
const primaryJsonLd =
  type === "article" && publishedDate
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title.replace(/ - Start Debugging$/, ""),
        description: description ?? "",
        url: canonical,
        mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
        image: [ogImageUrl],
        datePublished: publishedDate.toISOString(),
        ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
        ...(tags?.length ? { keywords: tags.join(", ") } : {}),
        inLanguage: ogLocale.replace("_", "-"),
        author,
        publisher,
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: siteName,
        url: siteUrl,
        inLanguage: ogLocale.replace("_", "-"),
        publisher,
      };

// BreadcrumbList for post pages. Home -> post title.
let breadcrumbJsonLd: Record<string, unknown> | null = null;
if (type === "article" && publishedDate) {
  const homeUrl = lang === "en" ? siteUrl + "/" : `${siteUrl}/${lang}/`;
  breadcrumbJsonLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: siteName,
        item: homeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: title.replace(/ - Start Debugging$/, ""),
        item: canonical,
      },
    ],
  };
}

// AI-search optimization: emit FAQPage / HowTo schema for templated posts.
// Only English posts ship this for now — translated posts share the canonical
// JSON-LD via the en URL and we don't want to mint divergent FAQs per locale.
let faqJsonLd: Record<string, unknown> | null = null;
let howToJsonLd: Record<string, unknown> | null = null;
if (type === "article" && body && template && lang === "en") {
  const cleanTitle = title.replace(/ - Start Debugging$/, "");
  if (template === "error-page") {
    const faqs = extractFaqFromMarkdown(body, cleanTitle);
    if (faqs) faqJsonLd = buildFaqPageJsonLd(faqs);
  } else if (template === "how-to" || template === "migration") {
    const steps = extractHowToFromMarkdown(body);
    if (steps) {
      howToJsonLd = buildHowToJsonLd({
        name: cleanTitle,
        description,
        steps,
        url: canonical,
        image: ogImageUrl,
      });
    }
  }
}

// RSS feed URL for the active language.
const rssUrl = lang === "en" ? `${siteUrl}/rss.xml` : `${siteUrl}/${lang}/rss.xml`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="icon" type="image/jpeg" href={`${baseUrl}brand-logo.ico`} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={rssUrl} />
    {/* Cross-locale RSS alternates for feed-reader discovery. We deliberately
        omit `hreflang` here: Google groups any rel=alternate[hreflang] into the
        page's language cluster regardless of `type`, which made the per-locale
        rss.xml URLs collide with the HTML translations in GSC ("More than one
        page is linked for the same language"). The localized `title` is enough
        for feed readers to label them. */}
    {LOCALES.filter((l) => l !== lang).map((l) => (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={`${siteName} (${LOCALE_HREFLANG[l]})`}
        href={l === "en" ? `${siteUrl}/rss.xml` : `${siteUrl}/${l}/rss.xml`}
      />
    ))}

    {/* hreflang alternates — only emit when this page has translations. */}
    {translations && translationEntries.length > 0 ? (
      <>
        <link rel="alternate" hreflang={LOCALE_HREFLANG[lang]} href={canonical} />
        {translationEntries.map(([l, href]) => (
          <link rel="alternate" hreflang={LOCALE_HREFLANG[l]} href={href} />
        ))}
        <link
          rel="alternate"
          hreflang="x-default"
          href={translations.en ?? canonical}
        />
      </>
    ) : null}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type === "article" ? "article" : "website"} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    {translationEntries.map(([l]) => (
      <meta property="og:locale:alternate" content={LOCALE_OG[l]} />
    ))}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {type === "article" && publishedDate ? (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    ) : null}
    {type === "article" && updatedDate ? (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    ) : null}
    {type === "article" && tags?.length
      ? tags.map((tag) => <meta property="article:tag" content={tag} />)
      : null}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@startdebugging_" />
    <meta name="twitter:creator" content="@mariusbughiu" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(primaryJsonLd)} />
    {breadcrumbJsonLd ? (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    ) : null}
    {faqJsonLd ? (
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    ) : null}
    {howToJsonLd ? (
      <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
    ) : null}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QFYE38MD6S"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-QFYE38MD6S');
    </script>

    <!-- Custom GA4 events: share clicks, scroll depth, outbound clicks,
         newsletter subscribe. See TRAFFIC_ROADMAP.md task 5.1. -->
    <script is:inline>
      (function () {
        function track(name, params) {
          if (typeof window.gtag !== 'function') return;
          window.gtag('event', name, params || {});
        }

        // Share row: any [data-share] anchor or the copy-link button.
        document.addEventListener('click', function (e) {
          var t = e.target instanceof Element ? e.target.closest('[data-share],[data-copy-link]') : null;
          if (!t) return;
          var network = t.getAttribute('data-share') || (t.hasAttribute('data-copy-link') ? 'copy' : null);
          if (!network) return;
          track('share_click', {
            network: network,
            page_path: location.pathname,
          });
        }, true);

        // Newsletter subscribe: footer form + inline post-page form. We can't
        // see the cross-origin Buttondown response so track on submit
        // intent — close enough for funnel measurement.
        document.addEventListener('submit', function (e) {
          var f = e.target instanceof HTMLFormElement ? e.target : null;
          if (!f) return;
          var action = (f.getAttribute('action') || '').toLowerCase();
          if (action.indexOf('buttondown.com') === -1) return;
          var tagInput = f.querySelector('input[name="tag"]');
          var placement = tagInput && tagInput.value ? tagInput.value : 'unknown';
          track('newsletter_subscribe', {
            placement: placement,
            page_path: location.pathname,
          });
        }, true);

        // Outbound clicks: any external <a> not on startdebugging.net.
        document.addEventListener('click', function (e) {
          var t = e.target instanceof Element ? e.target.closest('a[href]') : null;
          if (!t) return;
          var href = t.getAttribute('href') || '';
          if (!/^https?:\/\//i.test(href)) return;
          try {
            var u = new URL(href);
            if (u.hostname.endsWith('startdebugging.net')) return;
            track('outbound_click', {
              outbound_url: href,
              outbound_domain: u.hostname,
              page_path: location.pathname,
            });
          } catch (_err) { /* ignore */ }
        }, true);

        // Scroll depth: fire 25/50/75/100 once each per page.
        var fired = { 25: false, 50: false, 75: false, 100: false };
        var ticking = false;
        function scrollDepthCheck() {
          ticking = false;
          var doc = document.documentElement;
          var scrollTop = window.pageYOffset || doc.scrollTop || 0;
          var viewport = window.innerHeight || doc.clientHeight || 0;
          var fullHeight = Math.max(
            doc.scrollHeight,
            doc.offsetHeight,
            document.body ? document.body.scrollHeight : 0,
            document.body ? document.body.offsetHeight : 0,
          );
          var scrollable = Math.max(fullHeight - viewport, 1);
          var pct = (scrollTop / scrollable) * 100;
          [25, 50, 75, 100].forEach(function (mark) {
            if (!fired[mark] && pct >= mark) {
              fired[mark] = true;
              track('scroll_depth', { percent: mark, page_path: location.pathname });
            }
          });
        }
        window.addEventListener('scroll', function () {
          if (!ticking) {
            window.requestAnimationFrame(scrollDepthCheck);
            ticking = true;
          }
        }, { passive: true });
        // Catch short pages where the user never scrolls (still hit 25%).
        window.addEventListener('load', scrollDepthCheck);
      })();
    </script>

    {includeAdsense ? (
      <>
        <!-- Google AdSense (deferred). Loading the AdSense bundle eagerly tanks LCP/INP on
             mobile — defer until the page is idle or the user interacts.

             Also registers manual <ins.adsbygoogle> slots (top-of-post from
             AdSlot.astro, in-article from rehype-inject-ad.mjs) by pushing
             once per slot to window.adsbygoogle. Pushes are queue-safe — they
             buffer on the global array if the AdSense JS hasn't loaded yet,
             and get processed in DOM order once the lazy loader pulls in the
             script. Without these pushes, manual slots stay empty forever. -->
        <script is:inline>
          (function () {
            // Page-level slot registration. Idempotent via a marker attribute
            // so re-running (e.g. on Astro view-transition pageswap) only ever
            // pushes once per <ins>.
            function registerSlots() {
              var slots = document.querySelectorAll('ins.adsbygoogle:not([data-adsbygoogle-registered])');
              for (var i = 0; i < slots.length; i++) {
                slots[i].setAttribute('data-adsbygoogle-registered', '1');
                (window.adsbygoogle = window.adsbygoogle || []).push({});
              }
            }
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', registerSlots);
            } else {
              registerSlots();
            }

            // Lazy-load the AdSense bundle on first user interaction or, failing
            // that, when the browser is idle. Cap at 8s after `load` so
            // headless / no-interaction sessions still bring it in (ad fill
            // matters; abandonment matters less than CWV impact during the
            // initial paint).
            var loaded = false;
            function loadAdsense() {
              if (loaded) return;
              loaded = true;
              var s = document.createElement('script');
              s.async = true;
              s.crossOrigin = 'anonymous';
              s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1537458730659685';
              document.head.appendChild(s);
            }
            var events = ['scroll', 'pointerdown', 'keydown', 'touchstart'];
            function once() {
              events.forEach(function (e) { window.removeEventListener(e, once, { passive: true }); });
              loadAdsense();
            }
            events.forEach(function (e) { window.addEventListener(e, once, { passive: true, once: true }); });
            window.addEventListener('load', function () {
              if ('requestIdleCallback' in window) {
                window.requestIdleCallback(loadAdsense, { timeout: 8000 });
              } else {
                setTimeout(loadAdsense, 4000);
              }
            });
          })();
        </script>
      </>
    ) : null}
  </head>
  <body>
    <header>
      <div class="row header-row">
        <a class="pill" href={lang === "en" ? baseUrl : `${baseUrl}${lang}/`} style="padding: 4px 12px 4px 6px; gap: 8px;">
          <img src={`${baseUrl}brand-logo.jpg`} alt="" width="24" height="24" style="border-radius: 50%;" />
          <span style="line-height: 1; margin-bottom: -1px;">{t("site.brand", lang)}</span>
        </a>
        <div class="header-actions">
          <div class="header-search">
            <button
              type="button"
              class="pill header-search-trigger"
              data-search-open
              aria-label={t("search.openAria", lang)}
            >
              <span aria-hidden="true">&#x1F50D;</span>
              <span class="header-search-label">{t("search.label", lang)}</span>
              <kbd class="header-search-kbd" aria-hidden="true">/</kbd>
            </button>
          </div>
          {showLangSwitcher ? (
            <details class="header-lang">
              <summary class="pill header-lang-trigger" aria-label={`Language: ${LOCALE_NATIVE_NAME[lang]}`}>
                <span aria-hidden="true">&#x1F310;</span>
                <span class="header-lang-code">{LOCALE_SHORT_CODE[lang]}</span>
                <span class="header-lang-caret" aria-hidden="true">&#x25BE;</span>
              </summary>
              <ul class="header-lang-menu" role="menu">
                {translationEntries.map(([l, href]) => (
                  <li role="menuitem">
                    <a
                      href={href}
                      hreflang={LOCALE_HREFLANG[l]}
                      lang={LOCALE_HREFLANG[l]}
                      aria-label={LOCALE_NATIVE_NAME[l]}
                    >
                      <span class="header-lang-menu-code">{LOCALE_SHORT_CODE[l]}</span>
                      <span>{LOCALE_NATIVE_NAME[l]}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : null}
        </div>
      </div>
    </header>

    <div
      class="search-overlay"
      data-search-overlay
      hidden
      role="dialog"
      aria-modal="true"
      aria-labelledby="search-overlay-title"
    >
      <div class="search-overlay-backdrop" data-search-close aria-hidden="true"></div>
      <div class="search-overlay-panel panel">
        <div class="row search-overlay-header">
          <h2 class="h2" id="search-overlay-title">{t("search.heading", lang)}</h2>
          <button
            type="button"
            class="pill search-overlay-close"
            data-search-close
            aria-label={t("search.closeAria", lang)}
          >{t("search.close", lang)}</button>
        </div>
        <div id="pagefind-search"></div>
      </div>
    </div>

    <link rel="stylesheet" href={`${baseUrl}pagefind/pagefind-ui.css`} />
    <script is:inline define:vars={{ baseUrl, devHint: t("search.devHint", lang) }}>
      (function () {
        const overlay = document.querySelector('[data-search-overlay]');
        const opener = document.querySelector('[data-search-open]');
        const closers = document.querySelectorAll('[data-search-close]');
        if (!overlay || !opener) return;

        let loaded = false;
        function loadPagefind() {
          if (loaded) return Promise.resolve();
          loaded = true;
          return new Promise(function (resolve, reject) {
            const s = document.createElement('script');
            s.src = baseUrl + 'pagefind/pagefind-ui.js';
            s.onload = function () {
              try {
                // eslint-disable-next-line no-undef
                new PagefindUI({
                  element: '#pagefind-search',
                  showSubResults: true,
                  showImages: false,
                  resetStyles: false,
                });
                resolve();
              } catch (err) {
                reject(err);
              }
            };
            s.onerror = reject;
            document.head.appendChild(s);
          });
        }

        function openOverlay() {
          overlay.hidden = false;
          document.documentElement.style.overflow = 'hidden';
          loadPagefind().then(function () {
            const input = overlay.querySelector('input');
            if (input) input.focus();
          }).catch(function () {
            const target = overlay.querySelector('#pagefind-search');
            if (target && !target.dataset.devHint) {
              target.dataset.devHint = '1';
              target.innerHTML = '<p class="muted" style="padding:12px;">' + devHint + '</p>';
            }
          });
        }
        function closeOverlay() {
          overlay.hidden = true;
          document.documentElement.style.overflow = '';
        }

        opener.addEventListener('click', openOverlay);
        closers.forEach(function (c) { c.addEventListener('click', closeOverlay); });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !overlay.hidden) closeOverlay();
          if (
            e.key === '/' &&
            overlay.hidden &&
            !/^(input|textarea|select)$/i.test(document.activeElement && document.activeElement.tagName || '')
          ) {
            e.preventDefault();
            openOverlay();
          }
        });
      })();
    </script>

    <main>
      <slot />
    </main>

    <footer>
      <section class="footer-newsletter" aria-labelledby="footer-newsletter-heading">
        <h2 id="footer-newsletter-heading" class="h2 footer-newsletter-heading">
          {t("subscribe.footer.heading", lang)}
        </h2>
        <p class="muted footer-newsletter-copy">
          {t("subscribe.footer.blurb", lang)}
        </p>
        <form
          class="footer-newsletter-form row"
          action="https://buttondown.com/api/emails/embed-subscribe/startdebugging"
          method="post"
          target="popupwindow"
          onsubmit="window.open('https://buttondown.com/startdebugging', 'popupwindow');"
        >
          <label class="sr-only" for="footer-newsletter-email">Email address</label>
          <input
            id="footer-newsletter-email"
            class="footer-newsletter-input"
            type="email"
            name="email"
            placeholder={t("subscribe.footer.placeholder", lang)}
            required
            autocomplete="email"
          />
          <input type="hidden" name="tag" value="footer" />
          <button class="pill footer-newsletter-submit" type="submit">{t("subscribe.footer.submit", lang)}</button>
        </form>
        <p class="muted footer-newsletter-alt">
          {t("subscribe.footer.altRss", lang)} <a href={rssUrl}>{t("subscribe.footer.altRssLink", lang)}</a> {t("subscribe.footer.altRssAfter", lang)}
        </p>
      </section>

      <nav class="footer-nav row">
        <a href={lang === "en" ? `${baseUrl}about/` : `${baseUrl}${lang}/about/`}>{t("nav.about", lang)}</a>
        <a href={lang === "en" ? `${baseUrl}start-here/` : `${baseUrl}${lang}/start-here/`}>{t("nav.startHere", lang)}</a>
        <a href={lang === "en" ? `${baseUrl}pillars/` : `${baseUrl}${lang}/pillars/`}>{t("nav.pillars", lang)}</a>
        <a href={lang === "en" ? `${baseUrl}tags/` : `${baseUrl}${lang}/tags/`}>{t("nav.tags", lang)}</a>
        <a href={lang === "en" ? `${baseUrl}archive/` : `${baseUrl}${lang}/archive/`}>{t("nav.archive", lang)}</a>
        <a href={lang === "en" ? `${baseUrl}subscribe/` : `${baseUrl}${lang}/subscribe/`}>{t("nav.subscribe", lang)}</a>
        <a href={rssUrl}>{t("nav.rss", lang)}</a>
      </nav>
      <p class="footer-copy muted">
        &copy; {new Date().getFullYear()} {t("site.copyright", lang)}
      </p>
    </footer>
    <script is:inline>
      document.addEventListener("mousemove", (e) => {
        const cards = document.querySelectorAll(".post-card");
        for (const card of cards) {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty("--mouse-x", `${x}px`);
          card.style.setProperty("--mouse-y", `${y}px`);
        }
      });
    </script>
  </body>
</html>
