---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  includeAdsense?: boolean;
  canonicalUrl?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  type?: "website" | "article";
  /**
   * Site-relative path to the OG/Twitter image for this page, e.g.
   * `/og/2026/04/my-slug.png`. Falls back to `/og/default.png` when not
   * provided. Post pages should pass this explicitly.
   */
  ogImage?: string;
}

const {
  title,
  description,
  includeAdsense = false,
  canonicalUrl,
  publishedDate,
  updatedDate,
  tags,
  type = "website",
  ogImage,
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const siteUrl = Astro.site?.origin ?? "https://startdebugging.net";
const siteName = "Start Debugging";
const canonical = canonicalUrl ?? Astro.url.href;

// Absolute OG image URL. Fall back to the site-wide default card.
const ogImagePath = ogImage ?? "/og/default.png";
const ogImageUrl = new URL(ogImagePath, siteUrl).href;

// Author identity used in JSON-LD (mirrors site/src/pages/about.astro).
const author = {
  "@type": "Person",
  name: "Marius Bughiu",
  url: `${siteUrl}/about/`,
  sameAs: [
    "https://github.com/marius-startdebugging",
    "https://x.com/mariusstartdebugging",
    "https://www.linkedin.com/in/mariusstartdebugging/",
  ],
};

const publisher = {
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: `${siteUrl}/logo-512.png`,
    width: 512,
    height: 512,
  },
};

// JSON-LD structured data.
const primaryJsonLd =
  type === "article" && publishedDate
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title.replace(/ - Start Debugging$/, ""),
        description: description ?? "",
        url: canonical,
        mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
        image: [ogImageUrl],
        datePublished: publishedDate.toISOString(),
        ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
        ...(tags?.length ? { keywords: tags.join(", ") } : {}),
        author,
        publisher,
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: siteName,
        url: siteUrl,
        publisher,
      };

// BreadcrumbList for post pages. We only include URLs that actually resolve
// (Home -> post title). Year/month archive pages are a Phase 2 task; once
// they exist, add intermediate items here.
let breadcrumbJsonLd: Record<string, unknown> | null = null;
if (type === "article" && publishedDate) {
  breadcrumbJsonLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: siteName,
        item: siteUrl + "/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: title.replace(/ - Start Debugging$/, ""),
        item: canonical,
      },
    ],
  };
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={`${siteUrl}/rss.xml`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type === "article" ? "article" : "website"} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    {type === "article" && publishedDate ? (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    ) : null}
    {type === "article" && updatedDate ? (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    ) : null}
    {type === "article" && tags?.length
      ? tags.map((t) => <meta property="article:tag" content={t} />)
      : null}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mariusstartdebugging" />
    <meta name="twitter:creator" content="@mariusstartdebugging" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(primaryJsonLd)} />
    {breadcrumbJsonLd ? (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    ) : null}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QFYE38MD6S"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-QFYE38MD6S');
    </script>

    {includeAdsense ? (
      <>
        <!-- Google AdSense -->
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1537458730659685"
     crossorigin="anonymous"></script>
      </>
    ) : null}
  </head>
  <body>
    <header>
      <div class="row header-row">
        <a class="pill" href={baseUrl}>
          Start Debugging
        </a>
        <div class="header-search">
          <button
            type="button"
            class="pill header-search-trigger"
            data-search-open
            aria-label="Search posts"
          >
            <span aria-hidden="true">&#x1F50D;</span>
            <span class="header-search-label">Search</span>
            <kbd class="header-search-kbd" aria-hidden="true">/</kbd>
          </button>
        </div>
      </div>
    </header>

    <!-- Pagefind search overlay. The UI library is loaded lazily on first
         interaction so the homepage stays light. -->
    <div
      class="search-overlay"
      data-search-overlay
      hidden
      role="dialog"
      aria-modal="true"
      aria-labelledby="search-overlay-title"
    >
      <div class="search-overlay-backdrop" data-search-close aria-hidden="true"></div>
      <div class="search-overlay-panel panel">
        <div class="row search-overlay-header">
          <h2 class="h2" id="search-overlay-title">Search</h2>
          <button
            type="button"
            class="pill search-overlay-close"
            data-search-close
            aria-label="Close search"
          >Close</button>
        </div>
        <div id="pagefind-search"></div>
      </div>
    </div>

    <link rel="stylesheet" href={`${baseUrl}pagefind/pagefind-ui.css`} />
    <script is:inline define:vars={{ baseUrl }}>
      (function () {
        const overlay = document.querySelector('[data-search-overlay]');
        const opener = document.querySelector('[data-search-open]');
        const closers = document.querySelectorAll('[data-search-close]');
        if (!overlay || !opener) return;

        let loaded = false;
        function loadPagefind() {
          if (loaded) return Promise.resolve();
          loaded = true;
          return new Promise(function (resolve, reject) {
            const s = document.createElement('script');
            s.src = baseUrl + 'pagefind/pagefind-ui.js';
            s.onload = function () {
              try {
                // eslint-disable-next-line no-undef
                new PagefindUI({
                  element: '#pagefind-search',
                  showSubResults: true,
                  resetStyles: false,
                });
                resolve();
              } catch (err) {
                reject(err);
              }
            };
            s.onerror = reject;
            document.head.appendChild(s);
          });
        }

        function openOverlay() {
          overlay.hidden = false;
          document.documentElement.style.overflow = 'hidden';
          loadPagefind().then(function () {
            const input = overlay.querySelector('input');
            if (input) input.focus();
          }).catch(function () {
            // Pagefind index not built yet (e.g. astro dev). Show a hint.
            const target = overlay.querySelector('#pagefind-search');
            if (target && !target.dataset.devHint) {
              target.dataset.devHint = '1';
              target.innerHTML =
                '<p class="muted" style="padding:12px;">Search index not available in dev. Run <code>npm run build</code> to generate it.</p>';
            }
          });
        }
        function closeOverlay() {
          overlay.hidden = true;
          document.documentElement.style.overflow = '';
        }

        opener.addEventListener('click', openOverlay);
        closers.forEach(function (c) { c.addEventListener('click', closeOverlay); });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !overlay.hidden) closeOverlay();
          // "/" shortcut when not typing in a form field.
          if (
            e.key === '/' &&
            overlay.hidden &&
            !/^(input|textarea|select)$/i.test(document.activeElement && document.activeElement.tagName || '')
          ) {
            e.preventDefault();
            openOverlay();
          }
        });
      })();
    </script>

    <main>
      <slot />
    </main>

    <footer>
      <section class="footer-newsletter" aria-labelledby="footer-newsletter-heading">
        <h2 id="footer-newsletter-heading" class="h2 footer-newsletter-heading">
          Subscribe to the newsletter
        </h2>
        <p class="muted footer-newsletter-copy">
          A weekly digest of the best .NET, C#, MAUI, and Flutter posts on Start Debugging.
          No spam, unsubscribe anytime.
        </p>
        <form
          class="footer-newsletter-form row"
          action="https://buttondown.com/api/emails/embed-subscribe/startdebugging"
          method="post"
          target="popupwindow"
          onsubmit="window.open('https://buttondown.com/startdebugging', 'popupwindow');"
        >
          <label class="sr-only" for="footer-newsletter-email">Email address</label>
          <input
            id="footer-newsletter-email"
            class="footer-newsletter-input"
            type="email"
            name="email"
            placeholder="you@domain.com"
            required
            autocomplete="email"
          />
          <input type="hidden" name="tag" value="footer" />
          <button class="pill footer-newsletter-submit" type="submit">Subscribe</button>
        </form>
        <p class="muted footer-newsletter-alt">
          Prefer RSS? <a href={`${siteUrl}/rss.xml`}>Subscribe via RSS</a> instead.
        </p>
      </section>

      <nav class="footer-nav row">
        <a href={`${baseUrl}about/`}>About</a>
        <a href={`${baseUrl}start-here/`}>Start here</a>
        <a href={`${baseUrl}pillars/`}>Pillars</a>
        <a href={`${baseUrl}tags/`}>Tags</a>
        <a href={`${baseUrl}archive/`}>Archive</a>
        <a href={`${baseUrl}subscribe/`}>Subscribe</a>
        <a href={`${siteUrl}/rss.xml`}>RSS</a>
        <a href="https://github.com/marius-startdebugging/start-debugging" rel="noopener noreferrer">GitHub</a>
      </nav>
      <p class="footer-copy muted">
        &copy; {new Date().getFullYear()} Marius Bughiu. Built with Astro.
      </p>
    </footer>
  </body>
</html>
