# Start Debugging distribution credentials.
#
# Copy this file to `.env` and fill in the values you have. Any platform
# whose env vars are missing is silently skipped by the scripts.
#
# In GitHub Actions, set each of these as a repository secret under
# Settings -> Secrets and variables -> Actions. The workflows pass them
# straight into the job env.

# --- X (Twitter) -----------------------------------------------------------
# OAuth 1.0a user-context keys generated in https://developer.x.com
# Portal -> Your project -> App -> Keys and tokens.
# Remember to set App permissions to "Read and Write" in
# "User authentication settings" BEFORE generating the Access Token/Secret.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Bluesky ---------------------------------------------------------------
# https://bsky.app/settings/app-passwords
# Use the 19-char app password, NOT your main account password.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- Mastodon --------------------------------------------------------------
# <instance>/settings/applications -> New application -> scopes: read write.
# Copy "Your access token" into MASTODON_ACCESS_TOKEN.
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# --- dev.to ----------------------------------------------------------------
# https://dev.to/settings/extensions -> DEV Community API Keys.
DEVTO_API_KEY=

# --- Hashnode --------------------------------------------------------------
# https://hashnode.com/settings/developer -> Personal Access Token.
# Publication ID is the 24-char hex string in your publication's dashboard URL.
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# --- Buttondown (newsletter) ----------------------------------------------
# https://buttondown.com/settings/programming
BUTTONDOWN_API_KEY=

# --- LinkedIn --------------------------------------------------------------
# Access token from OAuth 2.0 flow with `w_member_social` scope.
# Author URN from GET /v2/me, looks like urn:li:person:abc123.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
