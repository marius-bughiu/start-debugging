# Start Debugging distribution credentials.
#
# Copy this file to `.env` and fill in the values you have. Any platform
# whose env vars are missing is silently skipped by the scripts.
#
# In GitHub Actions, set each of these as a repository secret under
# Settings -> Secrets and variables -> Actions. The workflows pass them
# straight into the job env.

# --- X (Twitter) -----------------------------------------------------------
# OAuth 1.0a user-context keys generated in https://developer.x.com
# Portal -> Your project -> App -> Keys and tokens.
# Remember to set App permissions to "Read and Write" in
# "User authentication settings" BEFORE generating the Access Token/Secret.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Bluesky ---------------------------------------------------------------
# https://bsky.app/settings/app-passwords
# Use the 19-char app password, NOT your main account password.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- Mastodon --------------------------------------------------------------
# <instance>/settings/applications -> New application -> scopes: read write.
# Copy "Your access token" into MASTODON_ACCESS_TOKEN.
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# --- dev.to ----------------------------------------------------------------
# https://dev.to/settings/extensions -> DEV Community API Keys.
DEVTO_API_KEY=

# --- Hashnode --------------------------------------------------------------
# https://hashnode.com/settings/developer -> Personal Access Token.
# Publication ID is the 24-char hex string in your publication's dashboard URL.
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# --- Buttondown (newsletter) ----------------------------------------------
# https://buttondown.com/settings/programming
BUTTONDOWN_API_KEY=

# --- Google PageSpeed Insights (CWV audit) --------------------------------
# Used by `npm run cwv-audit` (TRAFFIC_ROADMAP.md task 5.3).
# 1. https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com — Enable.
# 2. https://console.cloud.google.com/apis/credentials — Create credentials → API key.
# 3. (Recommended) Restrict the key to PageSpeed Insights API only.
PAGESPEED_API_KEY=

# --- Giscus (post comments) -----------------------------------------------
# Powers the comments widget at the bottom of post pages from 2024 onwards
# (TRAFFIC_ROADMAP.md task 6.4). All four PUBLIC_GISCUS_* vars must be set
# for the widget to render — leave any blank to keep comments off.
#
# These vars are PUBLIC_-prefixed so Astro inlines them at build time. They
# end up in the deployed HTML, which is fine: the IDs are not secrets and
# Giscus expects them to be readable client-side.
#
# Setup:
# 1. Create a public repo to back comments (recommended: a dedicated one
#    like `<your-username>/start-debugging-comments`, separate from the
#    blog source repo).
# 2. In that repo, enable Discussions: Settings → Features → Discussions.
# 3. Install the Giscus app: https://github.com/apps/giscus.
# 4. Create a Discussion category named "Blog comments" (Announcement
#    template — only maintainers can open new threads).
# 5. Visit https://giscus.app, point it at the comments repo, set
#    "Page ↔ Discussions Mapping" to **pathname**, pick the category, and
#    enable lazy loading. Copy the IDs from the generated <script> snippet
#    into the values below.
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=Blog comments
PUBLIC_GISCUS_CATEGORY_ID=
# Optional theme override (default: preferred_color_scheme). Other values:
# light, dark, dark_dimmed, transparent_dark, noborder_light, noborder_dark.
PUBLIC_GISCUS_THEME=preferred_color_scheme
